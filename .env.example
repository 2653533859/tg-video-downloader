# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== Telegram API ====================
# 必需：从 https://my.telegram.org 获取
TG_API_ID=12345
TG_API_HASH=your_api_hash_here

# ==================== Web 认证 ====================
# 必需：Web UI 登录凭据
WEB_AUTH_USERNAME=admin
WEB_AUTH_PASSWORD=your_secure_password

# ==================== 代理配置 ====================
# 可选：如果需要代理访问 Telegram（当前仅支持 http 类型）
TG_PROXY_ENABLED=false
TG_PROXY_TYPE=http
TG_PROXY_HOST=127.0.0.1
TG_PROXY_PORT=7890

# ==================== Relay 配置（在线播放） ====================
# PUBLIC_BASE_URL 用于生成外部播放器可访问的签名 URL
PUBLIC_BASE_URL=http://localhost:5003
RELAY_TOKEN_SECRET=change_this_to_random_string
RELAY_TOKEN_TTL=1800

# ==================== tdl 配置 ====================
# 可选：tdl 直连下载
TDL_BINARY=/usr/local/bin/tdl
TDL_NAMESPACE=default
TDL_STORAGE_PATH=/root/.tdl/data
TDL_THREADS=8
TDL_LIMIT=4

# ==================== 功能开关 ====================
DEBUG_API_ENABLED=false
OPEN_FOLDER_ENABLED=false
# 仅当部署在可信反向代理之后时才设为 true（否则 X-Forwarded-For 可被伪造绕过认证）
TRUST_FORWARDED_FOR=false
